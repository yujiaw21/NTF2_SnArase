#BHA_RR
#His-Asp(Glu) dyad attacking enone
#oxyanion stabilization by ARG

####Block 1: His nucleophile attacking enone####

#values in this block mainly derived from QM calculations

VARIABLE_CST::BEGIN

CST::BEGIN
 TEMPLATE::   ATOM_MAP: 1 atom_name: C1 C2 C12
 TEMPLATE::   ATOM_MAP: 1 residue3: BHA

 TEMPLATE::   ATOM_MAP: 2 atom_type: Nhis
 TEMPLATE::   ATOM_MAP: 2 residue3:  HIS

 CONSTRAINT:: distanceAB:     2.0    0.3  100.0    1   1
 CONSTRAINT::    angle_A:   109.0    5.0   50.0  360   1
 CONSTRAINT::    angle_B:   123.0    5.0   50.0  360   1
 CONSTRAINT::  torsion_A:   102.0    5.0   25.0  360   1 #<--- R-configuration
 CONSTRAINT:: torsion_AB:   -30.0    5.0   25.0  180   1
 CONSTRAINT::  torsion_B:   180.0   25.0   25.0  180   1 #double check

 ALGORITHM_INFO:: match   
  MAX_DUNBRACK_ENERGY  5.0 
 ALGORITHM_INFO::END

CST::END

CST::BEGIN
 TEMPLATE::   ATOM_MAP: 1 atom_name: C1 C2 C12
 TEMPLATE::   ATOM_MAP: 1 residue3: BHA

 TEMPLATE::   ATOM_MAP: 2 atom_type: Nhis
